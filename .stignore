# Syncthing ignore patterns mirrored from .gitignore.
# Syncthing uses first-match-wins, so include rules must come first.
# Gitignore exceptions
!.env.example
!.env.*.example
!.yarn/patches
!.yarn/patches/**
!.yarn/plugins
!.yarn/plugins/**
!.yarn/releases
!.yarn/releases/**
!.yarn/sdks
!.yarn/sdks/**
# Operating system
.DS_Store
Thumbs.db
ehthumbs.db
Desktop.ini
# Editor / IDE
.idea
.vscode
*.iml
*.ipr
*.iws
*.swp
*.swo
*~
# Local environment and secrets
.env
.env.*
# Logs and diagnostic reports
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*
report.[0-9]*.[0-9]*.[0-9]*.[0-9]*.json
# Node / package managers
node_modules
.npm
.pnpm-store
.yarn/**
jspm_packages
*.tgz
.yarn-integrity
# Coverage and tool caches
coverage
*.lcov
.nyc_output
.eslintcache
.cache
.parcel-cache
*.tsbuildinfo
# Vite / Electron / Electron Forge
desktop/.vite
desktop/dist
desktop/out
desktop/out-*
desktop/release
desktop/.webpack
desktop/build
desktop/output
desktop/**/*.asar
desktop/**/*.asar.unpacked
# Native Node / Rust artifacts
target
multi_platform_core/temp_napi
*.node
*.pdb
*.dll
*.dylib
*.so
*.a
*.lib
*.rs.bk
# Flutter / Dart
.dart_tool
.flutter-plugins
.flutter-plugins-dependencies
**/.flutter-plugins
**/.flutter-plugins-dependencies
.packages
**/.packages
.pub-cache
.pub
build
mobile/**/Flutter/Flutter.framework
mobile/**/Flutter/Flutter.podspec
mobile/**/Flutter/.last_build_id
mobile/**/flutter_export_environment.sh
mobile/**/Generated.xcconfig
mobile/android/.gradle
mobile/android/app/build
mobile/android/build
# Databases and app runtime state
*.db
*.db-shm
*.db-wal
*.sqlite
*.sqlite3
*.pid
*.pid.lock
*.seed
pids
# Local agent / workflow runtime state
.omx/state
.omx/logs
.omx/notepad.md
.omx/project-memory.json
.omx/metrics.json
# Temporary files
*.tmp
*.temp
