{
  "name": "guyantools",
  "productName": "GuYanTools",
  "version": "0.0.3",
  "description": "My Electron application description",
  "main": ".vite/build/index.js",
  "repository": "https://github.com/Sakurapole/GuYanTools",
  "scripts": {
    "prestart": "pnpm --dir .. run native:build:debug",
    "start": "electron-forge start",
    "prepackage": "pnpm --dir .. run native:build",
    "package": "electron-forge package",
    "premake": "pnpm --dir .. run native:build",
    "make": "electron-forge make",
    "build:main": "node scripts/build-electron-vite.mjs main",
    "build:preload": "node scripts/build-electron-vite.mjs preload",
    "build:preload-plugin": "node scripts/build-electron-vite.mjs preload-plugin",
    "build:renderer": "node scripts/build-electron-vite.mjs renderer",
    "build:app": "pnpm run build:main && pnpm run build:preload && pnpm run build:preload-plugin && pnpm run build:renderer",
    "dist:win": "pnpm --dir .. run native:build && pnpm run build:app && electron-builder --config electron-builder.config.cjs --win nsis",
    "publish": "pnpm run publish:github",
    "publish:github": "pnpm --dir .. run native:build && pnpm run build:app && electron-builder --config electron-builder.config.cjs --win nsis --publish always",
    "lint": "eslint --ext .ts,.tsx .",
    "lint:design-system": "node scripts/check-design-system.mjs",
    "verify:knowledge-editor": "node scripts/verify-knowledge-editor-foundation.cjs",
    "verify:ai-chat": "node scripts/verify-ai-chat.cjs"
  },
  "devDependencies": {
    "@electron-forge/cli": "^7.8.1",
    "@electron-forge/maker-deb": "^7.8.1",
    "@electron-forge/maker-rpm": "^7.8.1",
    "@electron-forge/maker-wix": "7.11.1",
    "@electron-forge/maker-zip": "^7.8.1",
    "@electron-forge/plugin-auto-unpack-natives": "^7.8.1",
    "@electron-forge/plugin-fuses": "^7.8.1",
    "@electron-forge/plugin-vite": "^7.8.1",
    "@electron-forge/publisher-github": "^7.11.1",
    "@electron/fuses": "^1.8.0",
    "@iconify/vue": "^5.0.0",
    "@intlify/unplugin-vue-i18n": "^6.0.8",
    "@types/node": "^24.1.0",
    "@typescript-eslint/eslint-plugin": "^8.39.1",
    "@typescript-eslint/parser": "^8.39.1",
    "@vitejs/plugin-vue": "^6.0.1",
    "@vue/tsconfig": "^0.7.0",
    "electron": "37.2.1",
    "electron-builder": "^26.0.12",
    "electron-rebuild": "^3.2.9",
