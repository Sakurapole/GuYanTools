{
  "name": "@guyantools/core",
  "version": "0.1.0",
  "main": "index.js",
  "types": "index.d.ts",
  "files": [
    "index.js",
    "index.d.ts",
    "multi-platform-core.win32-x64-msvc.node",
    "multi-platform-core.win32-arm64-msvc.node",
    "multi-platform-core.darwin-x64.node",
    "multi-platform-core.darwin-arm64.node",
    "multi-platform-core.linux-x64-gnu.node",
    "multi-platform-core.linux-arm64-gnu.node"
  ],
  "napi": {
    "binaryName": "multi-platform-core",
    "targets": [
      "x86_64-pc-windows-msvc",
      "aarch64-pc-windows-msvc",
      "aarch64-apple-darwin",
      "x86_64-apple-darwin",
      "x86_64-unknown-linux-gnu",
      "aarch64-unknown-linux-gnu"
    ]
  },
  "scripts": {
    "build": "napi build --platform --release --features napi && node scripts/patch-index-js.cjs && node scripts/write-index-dts.cjs",
    "build:debug": "napi build --platform --features napi && node scripts/patch-index-js.cjs && node scripts/write-index-dts.cjs",
    "artifacts": "node -e \"const fs=require('fs'); console.log(fs.readdirSync('.').filter((file)=>file.endsWith('.node')).join('\\n'))\"",
    "clean": "node scripts/clean-native-artifacts.cjs"
  },
  "devDependencies": {
    "@napi-rs/cli": "^3.4.1"
  }
}
